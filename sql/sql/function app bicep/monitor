// ── ACTION GROUP ─────────────────────────────────────────────
// This is your email contact list - who gets notified

resource actionGroup 'Microsoft.Insights/actionGroups@2023-01-01' = {
  name: actionGroupName
  location: 'global'  // Action groups must be global
  properties: {
    groupShortName: actionGroupShortName  // Max 12 chars - shown in emails
    enabled: true

    // Email receivers - one entry per person
    emailReceivers: [for (email, i) in alertEmailAddresses: {
      name: email.name
      emailAddress: email.emailAddress
      useCommonAlertSchema: true  // Standardised email format - easier to read
    }]

    // You can add more receiver types here if needed in future:
    // smsReceivers: []       // Text messages
    // webhookReceivers: []   // Teams/Slack integration
    // voiceReceivers: []     // Phone calls
    // logicAppReceivers: []  // Automated workflows
  }
  tags: {
    environment: 'production'
    application: 'IR'
    purpose: 'alerting'
  }
}

// ── ALERT RULE ───────────────────────────────────────────────
// This is the actual alert - the condition that triggers emails

resource alertRule 'Microsoft.Insights/scheduledQueryRules@2023-03-15-preview' = {
  name: alertRuleName
  location: location
  properties: {
    displayName: alertRuleName
    description: 'Triggers when failed IR application requests exceed ${failureThreshold} failures in 5 minutes'
    enabled: true
    severity: 2  // 0=Critical, 1=Error, 2=Warning, 3=Informational, 4=Verbose

    // How often to run the query and check
    evaluationFrequency: 'PT5M'   // PT5M = every 5 minutes
    windowSize: 'PT5M'            // PT5M = look at last 5 minutes of data

    // Where to run the query
    scopes: [
      logAnalyticsWorkspaceId
    ]

    // The KQL query that detects failures
    criteria: {
      allOf: [
        {
          // This is the query that runs every 5 minutes
          query: '''
            AppRequests
            | where TimeGenerated > ago(5m)
            | where AppRoleName in (${appNamesKql})
            | where Success == false
            | summarize FailedCount = sum(ItemCount)
          '''

          // How to measure the query results
          metricMeasureColumn: null   // null = count table rows
          resourceIdColumn: null
          operator: 'GreaterThan'     // Fire when count IS GREATER THAN threshold
          threshold: failureThreshold // Default: 50 failures
          timeAggregation: 'Count'    // Count the rows returned

          // How many consecutive violations before firing
          // 1 = fire immediately when threshold exceeded
          // 3 = only fire if threshold exceeded 3 times in a row (reduces false alarms)
          failingPeriods: {
            numberOfEvaluationPeriods: 1
            minFailingPeriodsToAlert: 1
          }
        }
      ]
    }

    // Connect to action group (send emails)
    actions: {
      actionGroups: [
        actionGroup.id  // Reference to the action group we created above
      ]
      customProperties: {
        'Email.Subject': 'IR-Failed-Request-'  // Email subject line
      }
    }

    // Alert behaviour settings
    autoMitigate: true   // Auto-resolve when condition clears (failures drop below 50)
    checkWorkspaceAlertsStorageConfigured: false
  }
  tags: {
    environment: ''
    application: 'IR'
    purpose: 'alerting'
  }

  // Make sure action group exists before creating alert
  dependsOn: [
    actionGroup
  ]
}

// ── OUTPUTS ──────────────────────────────────────────────────
// These print useful info after deployment

output workbookId string = workbook.id
output workbookName string = workbook.properties.displayName
output actionGroupId string = actionGroup.id
output actionGroupName string = actionGroup.name
output alertRuleId string = alertRule.id
output alertRuleName string = alertRule.name
output deploymentSummary object = {
  workbook: workbook.properties.displayName
  actionGroup: actionGroup.name
  alertRule: alertRule.name
  emailCount: length(alertEmailAddresses)
  failureThreshold: failureThreshold
  evaluationFrequency: '5 minutes'
  location: location
}
