// ============================================================
// IR Monitoring - Complete Bicep Deployment
// Deploys: Workbook + Alert Rule + Action Group
// Environment: PRD (Production)
// ============================================================

// ── PARAMETERS ──────────────────────────────────────────────
// These are the inputs you can change when deploying

@description('Azure region to deploy everything into')
param location string = 'uksouth'

@description('Your Log Analytics Workspace name')
param logAnalyticsWorkspaceName string = 'logmane'

@description('Resource group where Log Analytics workspace lives')
param logAnalyticsResourceGroup string = 'rgnameE'

@description('Your subscription ID')
param subscriptionId string = subscription().subscriptionId

@description('The two IR app names to monitor')
param appNames array = [
  'appservername1'
  'appservername2'
]

@description('Email addresses to send alerts to - add as many as needed')
param alertEmailAddresses array = [
  {
    name: 'TeamMember1'
    emailAddress: 'member1@yourcompany.com'  // CHANGE THIS
  }
  {
    name: 'TeamMember2'
    emailAddress: 'member2@yourcompany.com'  // CHANGE THIS
  }
  {
    name: 'TeamMember3'
    emailAddress: 'member3@yourcompany.com'  // CHANGE THIS
  }
]

@description('How many failures in 5 minutes before alert fires')
param failureThreshold int = 50

// ── VARIABLES ────────────────────────────────────────────────
// These are computed values used throughout the script

var workbookName = 'IR-app-monitoring'
var workbookDisplayName = 'IR Application Monitoring'
var actionGroupName = 'Platform'
var actionGroupShortName = 'Alert'
var alertRuleName = 'IR-failed-request'

// Build the app name filter string for KQL queries
// This creates: "app1", "app2" format for the 'in' operator
var appNamesKql = '"${join(appNames, '", "')}"'

// Full resource ID of the Log Analytics workspace
var logAnalyticsWorkspaceId = '/subscriptions/${subscriptionId}/resourceGroups/${logAnalyticsResourceGroup}/providers/Microsoft.OperationalInsights/workspaces/${logAnalyticsWorkspaceName}'

// ── WORKBOOK ─────────────────────────────────────────────────
// This is your dashboard - all 5 queries in one workbook

resource workbook 'Microsoft.Insights/workbooks@2022-04-01' = {
  name: guid(workbookName)  // Creates a unique ID based on the name
  location: location
  kind: 'shared'
  properties: {
    displayName: workbookDisplayName
    description: 'This workbook shows request volume, failures, latency, exceptions and dependency health for the IR application.'
    serializedData: string(loadJsonContent('workbook-template.json'))  // See note below
    version: '1.0'
    category: 'workbook'
    sourceId: logAnalyticsWorkspaceId
  }
  tags: {
    environment: 'production'
    application: 'IR'
    purpose: 'monitoring'
  }
}

