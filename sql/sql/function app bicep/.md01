// ============================================
// FIXED FUNCTION APP MODULES
// Add these after your managedIdentities module (around line 486)
// Uses correct output format from your userManagedIdentity module
// ============================================

// // Variables to find index of umi
var cdbBridgeEtlFunctionTargetUmiIndex = indexOf(map(identities, id => id.name), cdbBridgeEtlFunctionUmiName)
var caseworkerBridgeEtlFunctionTargetUmiIndex = indexOf(map(identities, id => id.name), caseworkerBridgeEtlFunctionUmiName)
var dequeueServiceFunctionTargetUmiIndex = indexOf(map(identities, id => id.name), dequeueServiceFunctionUmiName)
var queueManagerServiceFunctionTargetUmiIndex = indexOf(map(identities, id => id.name), queueManagerServiceFunctionUmiName)

// Function App 1: CDB to Bridge ETL
module cdbToBridgeFunction '../../modules/Compute/functionApp.bicep' = {
  name: 'deploy-cdb-bridge-function'
  params: {
    location: location
    functionAppName: 'vos-iaz-func-${environment}-bridge-cdb-bridge-etl'
    functionAppDotnetFrameworkVersion: dotnetVersion
    functionAppVirtualNetworkResourceGroupName: vnetResourceGroupName
    functionAppVirtualNetworkName: vnetName
    functionAppSubnetName: integrationSubnetName
    functionAppPrivateEndpointSubnetName: privateEndpointSubnetName
    functionAppUserAssignedManagedIdentityClientId: managedIdentities.outputs.clientIds[cdbBridgeEtlFunctionTargetUmiIndex]
    functionAppUserAssignedIdentityId: managedIdentities.outputs.identityResourceIds[cdbBridgeEtlFunctionTargetUmiIndex]
    functionAppPlanId: appServicePlanId
    functionAppMinimumElasticInstanceCount: minimumElasticInstanceCount
    applicationInsightsConnectionString: appInsights.outputs.connectionString
    tags: union(tags, {
      Purpose: 'CDB to Bridge ETL'
      FunctionType: 'DataTransport'
    })
  }
  dependsOn: [
    appInsights
    managedIdentities
  ]
}

